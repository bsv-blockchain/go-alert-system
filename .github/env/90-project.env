# ================================================================================================
# 🚀 PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-alert-system
# Load Order: 90 (loaded late, overrides all default env files)
#
# This file contains project-specific configuration that overrides defaults from earlier env files.
# It is the recommended place for any customization unique to this repository, including:
# - Coverage provider and token settings
# - CVE exclusion lists for vulnerability scanning
# - Coverage path exclusions matching codecov.yml
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER OVERRIDES
# ================================================================================================

# Use Codecov as the coverage provider (overrides 10-coverage.env default of "internal")
GO_COVERAGE_PROVIDER=codecov

# Require a Codecov token for uploads
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS (matches codecov.yml ignore paths)
# ================================================================================================

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/

# ================================================================================================
# 🛡️ CVE EXCLUSION OVERRIDES
# ================================================================================================

# Custom exclusions for AskNancy vulnerability scanning
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-24051,CVE-2026-26014,CVE-2025-65637,CVE-2026-33809,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-39883,CVE-2026-5160,CVE-2026-33812,CVE-2026-33813

# Custom exclusions for Govulncheck/Magex vulnerability scanning
MAGE_X_CVE_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-24051,CVE-2026-26014,CVE-2025-65637,CVE-2026-33809,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-39883,CVE-2026-5160,CVE-2026-33812,CVE-2026-33813
